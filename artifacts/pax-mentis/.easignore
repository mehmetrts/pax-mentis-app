# Reduce EAS Build archive size

# Geliştirme klasörleri
node_modules/
.expo/
.git/

# Dokümantasyon
*.md
docs/
GITHUB_SETUP.md

# Test ve geliştirme dosyaları
__tests__/
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts

# IDE ve editor
.vscode/
.idea/
*.swp

# OS dosyaları
.DS_Store
Thumbs.db

# Log dosyaları
*.log
npm-debug.log*
yarn-debug.log*

# Build çıktıları (farklı platform)
web-build/
dist/

# Mockup ve tasarım
../../artifacts/mockup-sandbox/

# Attached assets (build için gerekmez)
../../attached_assets/

# Scripts (build için gerekmez)
../../scripts/
