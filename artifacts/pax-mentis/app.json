{
  "expo": {
    "name": "Pax Mentis",
    "slug": "pax-mentis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pax-mentis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a2e1a"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Pax Mentis konuşmanı dinleyerek seni daha iyi anlayabilir.",
        "NSMicrophoneUsageDescription": "Pax Mentis sesinle sorularına yanıt vermek için mikrofona ihtiyaç duyar.",
        "NSCalendarsUsageDescription": "Pax Mentis yaklaşan etkinliklerini okuyarak yoğunluğunu anlayabilir. Tüm veriler yalnızca cihazında işlenir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a2e1a"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_CALENDAR"
      ],
      "minSdkVersion": 26,
      "package": "com.mehmetrts.paxmentis"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Pax Mentis sesinle sorularına yanıt vermek için mikrofona ihtiyaç duyar.",
          "speechRecognitionPermission": "Pax Mentis konuşmanı dinleyerek seni daha iyi anlayabilir."
        }
      ],
      [
        "llama.rn",
        {
          "enableOpenCLAndHexagon": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "0e9a6488-eb86-48c0-b01e-d53ac687dac0"
      }
    }
  }
}
